{
  "name": "kastellix",
  "version": "0.1.0",
  "private": false,
  "main": "dist/Kastellix.umd.js",
  "module": "dist/Kastellix.common.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "author": "Tjut",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "serve": "vue-cli-service serve",
    "dev": "npm run serve",
    "build": "npm run build:lib && npm run build:style",
    "build:lib": "NODE_OPTIONS=--no-deprecation vue-cli-service build --target lib --name Kastellix src/index.ts",
    "build:style": "postcss src/assets/tailwind.css -o dist/style.css",
    "lint": "vue-cli-service lint --no-fix"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@vue/cli-plugin-babel": "~5.0.9",
    "@vue/cli-plugin-eslint": "~5.0.9",
    "@vue/cli-plugin-typescript": "^5.0.9",
    "@vue/cli-service": "~5.0.9",
    "autoprefixer": "^10.5.0",
    "eslint": "9.26.0",
    "eslint-plugin-vue": "^8.7.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/typescript/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {}
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
